{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/New_York",
  "schedule": ["* 22-23,0-5 * * *"],
  "labels": ["dependencies"],

  "nix": {
    "enabled": true
  },

  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },

  "packageRules": [
    {
      "description": "Auto-merge routine updates after CI passes",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Major bumps stay manual",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
